@* =========================================================
   Botón flotante tipo FAB (Home dinámico según menú)
========================================================= *@

<link href="~/css/BotonMenu.css?v=1.4" rel="stylesheet" />

<div class="fab-wrap" data-fab>
    <a class="fab-main"
       id="btnFabInicio"
       href="/Home"
       title="Inicio · click derecho 0.5s para mover"
       data-bs-toggle="tooltip"
       data-bs-placement="right"
       data-bs-trigger="hover">
        <i class="fa fa-home"></i>
        <span class="fab-label d-none d-md-inline">Inicio</span>
    </a>
</div>

<script>
(function () {
    var FAB_HOLD_MS = 500;
    var LS_FAB_POS = 'fab_inicio_pos';
    var LS_MENU = 'menu_tipo';

    function irHome() {
        if (typeof window.redirigirSegunMenu === 'function') {
            window.redirigirSegunMenu();
            return;
        }
        var menu = null;
        try { menu = localStorage.getItem(LS_MENU); } catch (e) {}
        window.location.href = (menu === 'personalizado') ? '/HomePersonalizada' : '/Home';
    }

    // Expuesta por si hace falta desde afuera
    window.redirigirSegunMenuFab = irHome;

    document.querySelectorAll('[data-fab] [data-bs-toggle="tooltip"]').forEach(function (el) {
        try { new bootstrap.Tooltip(el); } catch (e) {}
    });

    var fab = document.querySelector('[data-fab]');
    if (!fab) return;
    var main = fab.querySelector('.fab-main');
    if (!main) return;

    var holdTimer = null;
    var dragArmed = false;
    var dragging = false;
    var tracking = false;
    var skipNextClick = false;
    var startX = 0, startY = 0, lastX = 0, lastY = 0, offsetX = 0, offsetY = 0;

    function clamp(n, min, max) {
        return Math.max(min, Math.min(max, n));
    }

    function applyPos(left, top) {
        var w = fab.offsetWidth || 56;
        var h = fab.offsetHeight || 56;
        var L = clamp(left, 8, Math.max(8, window.innerWidth - w - 8));
        var T = clamp(top, 8, Math.max(8, window.innerHeight - h - 8));
        fab.style.left = L + 'px';
        fab.style.top = T + 'px';
        fab.style.right = 'auto';
        fab.style.bottom = 'auto';
        return { left: L, top: T };
    }

    function savePos(left, top) {
        try { localStorage.setItem(LS_FAB_POS, JSON.stringify({ left: left, top: top })); } catch (e) {}
    }

    function restorePos() {
        try {
            var raw = localStorage.getItem(LS_FAB_POS);
            if (!raw) return;
            var pos = JSON.parse(raw);
            if (pos && isFinite(Number(pos.left)) && isFinite(Number(pos.top))) {
                applyPos(Number(pos.left), Number(pos.top));
                fab.classList.add('is-custom-pos');
            }
        } catch (e) {}
    }

    function clearHold() {
        if (holdTimer) { clearTimeout(holdTimer); holdTimer = null; }
        fab.classList.remove('is-holding');
    }

    function armDrag(x, y) {
        dragArmed = true;
        fab.classList.remove('is-holding');
        fab.classList.add('is-drag-ready');
        var rect = fab.getBoundingClientRect();
        offsetX = x - rect.left;
        offsetY = y - rect.top;
        try { if (navigator.vibrate) navigator.vibrate(18); } catch (e) {}
    }

    function detachDocListeners() {
        document.removeEventListener('mousemove', onDocMouseMove, true);
        document.removeEventListener('mouseup', onDocMouseUp, true);
        document.removeEventListener('touchmove', onDocTouchMove, true);
        document.removeEventListener('touchend', onDocTouchEnd, true);
        document.removeEventListener('touchcancel', onDocTouchEnd, true);
    }

    function endTrack() {
        if (!tracking) return;
        tracking = false;
        clearHold();
        if (dragging) {
            var rect = fab.getBoundingClientRect();
            var pos = applyPos(rect.left, rect.top);
            savePos(pos.left, pos.top);
            fab.classList.add('is-custom-pos');
            skipNextClick = true;
        } else if (dragArmed) {
            skipNextClick = true;
        }
        dragging = false;
        dragArmed = false;
        fab.classList.remove('is-drag-ready', 'is-dragging', 'is-holding');
        detachDocListeners();
    }

    function onMove(x, y) {
        lastX = x;
        lastY = y;
        if (!dragArmed) {
            if (Math.hypot(x - startX, y - startY) > 14) clearHold();
            return;
        }
        dragging = true;
        fab.classList.add('is-dragging');
        applyPos(x - offsetX, y - offsetY);
    }

    function onDocMouseMove(e) {
        if (!tracking) return;
        onMove(e.clientX, e.clientY);
    }

    function onDocMouseUp() {
        endTrack();
    }

    function onDocTouchMove(e) {
        if (!tracking || !e.touches[0]) return;
        // Solo bloquear scroll cuando ya se puede arrastrar
        if (dragArmed) e.preventDefault();
        onMove(e.touches[0].clientX, e.touches[0].clientY);
    }

    function onDocTouchEnd() {
        endTrack();
    }

    function startHold(x, y) {
        tracking = true;
        dragArmed = false;
        dragging = false;
        startX = lastX = x;
        startY = lastY = y;
        fab.classList.add('is-holding');
        clearHold();
        holdTimer = setTimeout(function () {
            if (!tracking) return;
            armDrag(lastX, lastY);
        }, FAB_HOLD_MS);
    }

    restorePos();

    // ——— Click izquierdo / tap → Home (siempre) ———
    main.addEventListener('click', function (e) {
        if (skipNextClick) {
            e.preventDefault();
            e.stopPropagation();
            skipNextClick = false;
            return;
        }
        e.preventDefault();
        irHome();
    });

    // ——— Click derecho 2s → mover ———
    main.addEventListener('contextmenu', function (e) {
        e.preventDefault();
    });

    main.addEventListener('mousedown', function (e) {
        if (e.button !== 2) return;
        e.preventDefault();
        startHold(e.clientX, e.clientY);
        document.addEventListener('mousemove', onDocMouseMove, true);
        document.addEventListener('mouseup', onDocMouseUp, true);
    });

    // ——— Táctil: long-press 2s → mover (no interfiere con tap corto) ———
    main.addEventListener('touchstart', function (e) {
        if (!e.touches[0]) return;
        startHold(e.touches[0].clientX, e.touches[0].clientY);
        document.addEventListener('touchmove', onDocTouchMove, { capture: true, passive: false });
        document.addEventListener('touchend', onDocTouchEnd, true);
        document.addEventListener('touchcancel', onDocTouchEnd, true);
    }, { passive: true });

    window.addEventListener('resize', function () {
        if (!fab.classList.contains('is-custom-pos')) return;
        var rect = fab.getBoundingClientRect();
        var pos = applyPos(rect.left, rect.top);
        savePos(pos.left, pos.top);
    });
})();
</script>
