@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

@{
    ViewData["Title"] = "Monedas";
}

@section Estilos {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
    <link rel="stylesheet" href="~/css/redisenopantallas.css?v=1.1" />
    <link rel="stylesheet" href="~/css/monedas.css?v=2.0" asp-append-version="true" />
}

<partial name="~/Views/Shared/Partials/BotonMenu.cshtml" />

<div class="monedas-page page-99">
    <div class="cc-header shadow-lg rounded-4 p-4 mb-4">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="d-flex align-items-center gap-3">
                <span class="cc-badge mon-badge"><i class="fa fa-money"></i></span>
                <div>
                    <h2 class="m-0 fw-800">Monedas</h2>
                    <small class="text-muted-cc">Cotizaciones para pedidos y gastos</small>
                </div>
            </div>
            <div class="ms-auto d-flex gap-3 flex-wrap align-items-center">
                <div class="cc-stat">
                    <div class="label">Activas</div>
                    <div class="value"><strong id="kpiMonedasCount">0</strong></div>
                </div>
                <button type="button" class="btn btn-monedas-export" id="btnExportarMonedas" title="Exportar listado">
                    <i class="fa fa-download me-1"></i> Exportar
                </button>
            </div>
        </div>
    </div>

    <div class="card-glass monedas-panel p-4">
        <div class="monedas-panel__head">
            <span><i class="fa fa-th-large me-2"></i> Cotizaciones vigentes</span>
            <span class="monedas-panel__hint">Tocá una tarjeta para editar o usá <strong>+</strong> para agregar</span>
        </div>
        <div id="monedasContainer" class="monedas-grid" aria-live="polite"></div>
    </div>
</div>

<div class="modal fade" id="modalEdicion" tabindex="-1" aria-labelledby="modalEdicionLabel" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-moneda">
        <div class="modal-content mon-modal">
            <div class="modal-header mon-modal__head">
                <h5 class="modal-title fw-800 m-0" id="modalEdicionLabel">Moneda</h5>
                <button type="button" class="btn-close btn-close-white" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <form id="formEditarMoneda" class="row g-3">
                    <input type="text" id="txtId" hidden readonly>
                    <div class="col-md-6">
                        <label for="txtNombre" class="form-label">Nombre (*)</label>
                        <input type="text" class="form-control" id="txtNombre" required>
                    </div>
                    <div class="col-md-6">
                        <label for="txtCotizacion" class="form-label">Cotización</label>
                        <input type="text" class="form-control" id="txtCotizacion" inputmode="decimal">
                    </div>
                    <div class="col-12 text-center mon-modal__img-wrap">
                        <label for="Imagen" class="form-label">Bandera / ícono</label>
                        <div class="mon-modal__preview">
                            <img id="imgMoneda" alt="Vista previa" />
                        </div>
                        <input id="Imagen" class="form-control" type="file" accept=".jpg,.jpeg,.png,.webp" />
                        <p id="imgMon" class="d-none"></p>
                    </div>
                </form>
            </div>
            <div class="modal-footer mon-modal__foot">
                <button type="button" class="btn btn-monedas-ghost" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" id="btnGuardar" class="btn btn-monedas-primary" onclick="guardarCambios()">Guardar</button>
            </div>
        </div>
    </div>
</div>

<partial name="~/Views/Utils/Modals.cshtml" />

@section Scripts {
    <script src="~/js/site.js"></script>
    <script src="~/js/Monedas.js?v=2.0" asp-append-version="true"></script>
}
