                                </div>
                            </div>
                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Ventas.png" class="img-fluid max-img-size" alt="Ventas" title="Ventas">
                                    <a class="btn mt-2 btnMenu" href="@Url.Action("Index", "Ventas")">Ventas</a>
                                </div>
                            </div>
                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
