                                    <a class="btn mt-2 btnMenu" href="@Url.Action("Index", "Proveedores")">Lista de Proveedores</a>
                                </div>
                            </div>
                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Choferes.png" class="img-fluid max-img-size" alt="Lista de Choferes" title="Lista de Choferes">
                                    <a class="btn mt-2 btnMenu" href="@Url.Action("Index", "Choferes")">Lista de Choferes</a>
                                </div>
                            </div>



                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Productos.png" class="img-fluid max-img-size" alt="Nuevo Producto" title="Nuevo Producto">
                                    <button type="button" class="btn mt-2 btnMenu" onclick="nuevoProducto()">Nuevo Producto</button>
                                </div>
                            </div>

                        @*      <div class="col">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Productos.png" class="img-fluid max-img-size" alt="Nuevo Producto" title="Nuevo Producto">
                                    <button type="button" class="btn mt-2 btnMenu" onclick="nuevoProducto()">Nuevo Producto</button>
                                </div>
                            </div>
 *@

                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Nuevo Cliente.png" class="img-fluid max-img-size" alt="Nuevo Cliente" title="Nuevo Cliente">
                                    <button type="button" class="btn mt-2 btnMenu" onclick="nuevoCliente()">Nuevo Cliente</button>
                                </div>
                            </div>

                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Proveedor.png" class="img-fluid max-img-size" alt="Nuevo Proveedor" title="Nuevo Proveedor">
                                    <button type="button" class="btn mt-2 btnMenu " onclick="nuevoProveedor()">Nuevo Proveedor</button>
                                </div>
                            </div>

                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Chofer.png" class="img-fluid max-img-size" alt="Nuevo Chofer" title="Nuevo Chofer">
                                    <button type="button" class="btn mt-2 btnMenu" onclick="nuevoChofer()">Nuevo Chofer</button>
                                </div>
                            </div>
                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/historialPrecios.png" class="img-fluid max-img-size" alt="Historial de Precios" title="Historial de Precios">
                                    <a class="btn mt-2 btnMenu" href="@Url.Action("Index", "HistorialPrecios")">Historial de Precios</a>
                                </div>
                            </div>
                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Monedas.png" class="img-fluid max-img-size" alt="Monedas" title="Monedas">
                                    <a class="btn mt-2 btnMenu" href="@Url.Action("Index", "Monedas")">Monedas</a>
                                </div>
                            </div>
                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Zonas.png" class="img-fluid max-img-size" alt="Lista de Zonas" title="Lista de Zonas">
                                    <a class="btn mt-2 btnMenu" href="@Url.Action("Index", "Zonas")">Lista de Zonas</a>
                                </div>
                            </div>
                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Nueva Zona.png" class="img-fluid max-img-size" alt="Nueva Zona" title="Nueva Zona">
                                    <button type="button" class="btn mt-2 btnMenu" onclick="nuevaZona()">Nueva Zona</button>
                                </div>
                            </div>

                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Usuarios.png" class="img-fluid max-img-size" alt="Lista de Usuarios" title="Lista de Usuarios">
                                    <a class="btn mt-2 btnMenu" href="@Url.Action("Index", "Usuarios")">Lista de Usuarios</a>
                                </div>
                            </div>

                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Nuevo Usuario.png" class="img-fluid max-img-size" alt="Nuevo Usuario" title="Nuevo Usuario">
                                    <button type="button" class="btn mt-2 btnMenu" onclick="nuevoUsuario()">Nuevo Usuario</button>
                                </div>
                            </div>

                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Acopio.png" class="img-fluid max-img-size" alt="Acopio Historial" title="Acopio Historial">
                                    <a class="btn mt-2 btnMenu" href="@Url.Action("Index", "AcopioHistorial")">Movimientos Acopio</a>
                                </div>
                            </div>


                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Gastos.png" class="img-fluid max-img-size" alt="Gastos" title="Gastos">
                                    <a class="btn mt-2 btnMenu" href="@Url.Action("Index", "Gastos")">Gastos</a>
                                </div>
                            </div>


                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Configuraciones.png" class="img-fluid max-img-size" alt="Configuraciones" title="Configuraciones">
                                    <button type="button" class="btn mt-2 btnMenu" onclick="abrirConfiguraciones()">Configuraciones</button>
                                </div>
                            </div>
                            <div class="col home-menu-item">
                                <div class="d-flex flex-column align-items-center">
                                    <img src="~/Imagenes/Menu Principal/Analisis.png" class="img-fluid max-img-size" alt="Reportes" title="Reportes">
                                    <a class="btn mt-2 btnMenu" href="@Url.Action("Index", "Reportes")">Reportes</a>
                                </div>
                            </div>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>


    <!-- Modal Configuraciones (lista/edici?n) -->
    <div class="modal fade theme-indigo" id="modalConfiguracion" tabindex="-1" aria-labelledby="modalConfiguracionLabel" aria-hidden="true">
        <div class="modal-dialog modal-lg modal-dialog-centered">
            <div class="modal-content modal-config shadow-lg border-0 rounded-3">

                <!-- Header -->
                <div class="modal-header">
                    <h5 class="modal-title fw-bold" id="modalConfiguracionLabel">
                        <i class="fa fa-cogs me-2"></i> Configuraci?n
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <!-- Body -->
                <div class="modal-body">
                    <!-- Mensaje vac?o (mismo id que el tuyo) -->
                    <div id="lblListaVacia" class="alert alert-warning text-center py-2 mb-3" hidden>No hay resultados.</div>

                    <!-- Contenedor lista + buscador -->
                    <div class="list-container border rounded-3 p-2">
                        <div class="mb-2">
                            <input type="text"
                                   class="form-control form-control-sm"
                                   id="txtBuscarConfig"
                                   placeholder="Buscar..."
                                   oninput="filtrarConfiguracionesLocal(this.value)">
                        </div>

                        <!-- Lista din?mica (mismo id que el tuyo) -->
                        <div id="configuracion-list" class="config-list">
                            <!-- ?tems din?micos -->
                        </div>
                    </div>

                    <!-- Formulario de edici?n (mismos ids que us?s) -->
                    <div id="contenedorNombreConfiguracion" class="mt-4" hidden>
                        <label for="txtNombreConfiguracion" class="form-label fw-bold">Nombre</label>
                        <input type="text" class="form-control" id="txtNombreConfiguracion" required>
                        <input type="hidden" id="txtIdConfiguracion">

                        <!-- Combo extra gen?rico (queda oculto si no lo us?s) -->
                        <div id="divConfiguracionCombo" class="mt-3" hidden>
                            <label id="lblConfiguracionCombo" for="cmbConfiguracion" class="form-label fw-bold"></label>
                            <select class="form-select" id="cmbConfiguracion" required>
                                <option value="">Seleccione...</option>
                            </select>
                        </div>

                        <div class="d-flex gap-2 mt-3">
                            <button id="btnRegistrarModificarConfiguracion"
                                    class="btn btn-success flex-fill"
                                    onclick="guardarCambiosConfiguracion()">
                                <i class="fa fa-save me-1"></i> Guardar cambios
                            </button>
                            <button type="button"
                                    class="btn btn-outline-secondary flex-fill"
                                    onclick="cancelarModificarConfiguracion()">
                                <i class="fa fa-times me-1"></i> Cancelar
                            </button>
                        </div>
                    </div>
                </div>

                <!-- Footer -->
                <div class="modal-footer d-flex justify-content-between">
                    <button id="agregarConfiguracion" class="btn btn-primary" onclick="agregarConfiguracion()">
                        <i class="fa fa-plus me-1"></i> A?adir
                    </button>
                    <button type="button" class="btn btn-outline-secondary" data-bs-dismiss="modal" onclick="abrirConfiguraciones()">
                        <i class="fa fa-times me-1"></i> Cerrar
                    </button>
                </div>

            </div>
        </div>
    </div>

    <!-- Modal Configuraciones (grid de accesos) -->
    <div class="modal fade theme-indigo" id="ModalEdicionConfiguraciones" tabindex="-1" aria-labelledby="ModalEdicionConfiguracionesLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-xl">
            <div class="modal-content modal-config">
                <div class="modal-header">
                    <h5 class="modal-title" id="ModalEdicionConfiguracionesLabel">
                        <i class="fa fa-cogs me-2"></i> Configuraciones
                    </h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <div class="modal-body py-3">
                    <!-- Grid responsiva: 1/2/3/4 columnas -->
                    <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 g-3" id="gridConfiguraciones">

                        <!-- Ejemplos: adapta tus opciones ac? -->
                        <div class="col">
                            <button type="button" class="config-card w-100"
                                    onclick="abrirConfiguracion('Categoria', 'Categorias')"
                                    data-label="Categoria" data-table="Categorias">
                                <img src="/Imagenes/Categorias.png" alt="" class="config-card__img" loading="lazy">
                                <span class="config-card__title">Categor?as</span>
                                <span class="config-card__subtitle">Organiza tu cat?logo</span>
                            </button>
                        </div>

                        <div class="col">
                            <button type="button" class="config-card w-100"
                                    onclick="abrirConfiguracion('Marca', 'Marcas')"
                                    data-label="Marca" data-table="Marcas">
                                <img src="/Imagenes/Marcas.png" alt="" class="config-card__img" loading="lazy">
                                <span class="config-card__title">Marcas</span>
                                <span class="config-card__subtitle">Alta, edici?n y baja</span>
                            </button>
                        </div>

                        <div class="col">
                            <button type="button" class="config-card w-100"
                                    onclick="abrirConfiguracion('Unidad de Medida', 'UnidadesDeMedidas')"
                                    data-label="Unidad de Medida" data-table="UnidadesDeMedidas">
                                <img src="/Imagenes/unidadmedida.png" alt="" class="config-card__img" loading="lazy">
                                <span class="config-card__title">Unidades de Medida</span>
                                <span class="config-card__subtitle">Gramos, litros, etc.</span>
                            </button>
                        </div>

                        <div class="col">
                            <button type="button" class="config-card w-100"
                                    onclick="abrirConfiguracion('Rol', 'Roles')"
                                    data-label="Rol" data-table="Roles">
                                <img src="/Imagenes/Roles.png" alt="" class="config-card__img" loading="lazy">
                                <span class="config-card__title">Roles</span>
                                <span class="config-card__subtitle">Permisos y accesos</span>
                            </button>
                        </div>

                        <div class="col">
                            <button type="button" class="config-card w-100"
                                    onclick="abrirConfiguracion('Tipo de Gasto', 'GastosTipos')"
                                    data-label="Rol" data-table="Gastos">
                                <img src="/Imagenes/configuraciones.png" alt="" class="config-card__img" loading="lazy">
                                <span class="config-card__title">Gastos</span>
                                <span class="config-card__subtitle">Tipos de Gastos</span>
                            </button>
                        </div>


                        <!-- Agreg? m?s items como necesites, copiando la tarjeta -->
                    </div>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-success px-4" data-bs-dismiss="modal">Aceptar</button>
                </div>
            </div>
        </div>
    </div>


    <div class="modal fade" id="ModalEdicionCliente" tabindex="-1" role="dialog" aria-labelledby="ModalEdicionClienteLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-edicion" role="document">
            <div class="modal-content">

                <div class="modal-header colorEncabezado">
                    <h5 class="modal-title fw-bold" id="ModalEdicionClienteLabel">Editar Cliente</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <div class="modal-body">
                    <form id="formEditarCliente" class="row g-3">
                        <input type="text" id="txtIdCliente" hidden readonly>

                        <div class="col-md-6">
                            <label for="txtNombreCliente" class="form-label">Nombre (*)</label>
                            <input type="text" class="form-control" id="txtNombreCliente" required>
                        </div>

                        <div class="col-md-6">
                            <label for="txtTelefonoCliente" class="form-label">Tel?fono</label>
                            <input type="text" class="form-control" id="txtTelefonoCliente">
                        </div>

                        <div class="col-md-6">
                            <label for="txtDireccionCliente" class="form-label">Direcci?n</label>
                            <input type="text" class="form-control" id="txtDireccionCliente">
                        </div>

                        <div class="col-md-6">
                            <label for="ProvinciasClientes" class="form-label">Provincia</label>
                            <select id="ProvinciasClientes" name="select" class="form-control">
                                <option value="" selected>Provincias</option>
                            </select>
                        </div>

                        <div class="col-md-6">
                            <label for="txtLocalidadCliente" class="form-label">Localidad</label>
                            <input type="text" class="form-control" id="txtLocalidadCliente">
                        </div>

                        <div class="col-md-6">
                            <label for="txtDNICliente" class="form-label">DNI</label>
                            <input type="text" class="form-control" id="txtDNICliente">
                        </div>
                    </form>
                </div>

                <div class="modal-footer">
                    <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                    <button type="button" id="btnGuardarCliente" class="btn btn-primary" onclick="guardarCambios()">Registrar</button>
                </div>

            </div>
        </div>
    </div>



    <div class="modal fade" id="ModalEdicionUsuario" tabindex="-1" role="dialog" aria-labelledby="ModalEdicionUsuarioLabel" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered modal-edicion" role="document">
            <div class="modal-content">
                <div class="modal-header colorEncabezado">
                    <h5 class="modal-title fw-bold" id="ModalEdicionUsuarioLabel">Editar Usuario</h5>
                    <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
                </div>

                <div class="modal-body">
                    <form id="formEditarUsuario" class="row g-3">
                        <input type="text" id="txtIdUsuario" hidden readonly>

                        <div class="col-md-4">
                            <label for="txtUserUsuario" class="form-label">Usuario (*)</label>
                            <input type="text" class="form-control" id="txtUserUsuario" required>
                        </div>

                        <div class="col-md-4">
                            <label for="txtNombreUsuario" class="form-label">Nombre (*)</label>
                            <input type="text" class="form-control" id="txtNombreUsuario" required>
                        </div>

                        <div class="col-md-4">
                            <label for="txtApellidoUsuario" class="form-label">Apellido (*)</label>
                            <input type="text" class="form-control" id="txtApellidoUsuario" required>
                        </div>

                        <div class="col-md-4">
                            <label for="txtDniUsuario" class="form-label">DNI</label>
                            <input type="text" class="form-control" id="txtDniUsuario">
                        </div>

                        <div class="col-md-4">
                            <label for="txtTelefonoUsuario" class="form-label">Tel?fono</label>
                            <input type="text" class="form-control" id="txtTelefonoUsuario">
                        </div>

                        <div class="col-md-4">
                            <label for="txtDireccionUsuario" class="form-label">Direcci?n</label>
                            <input type="text" class="form-control" id="txtDireccionUsuario">
                        </div>

                        <div class="col-md-4">
                            <label for="RolesUsuario" class="form-label">Rol</label>
                            <select id="RolesUsuario" class="form-control">
                                <option value="" selected>Rol</option>
                            </select>
                        </div>

                        <div class="col-md-4">
                            <label for="EstadosUsuario" class="form-label">Estado</label>
                            <select id="EstadosUsuario" class="form-control">
                                <option value="" selected>Estado</option>
                            </select>
