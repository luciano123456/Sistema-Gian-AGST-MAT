@{
    ViewData["Title"] = "Reportes";
}

@section Estilos {
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css" />
    <link href="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.0/css/select2.min.css" rel="stylesheet" />
    <link rel="stylesheet" href="~/css/redisenopantallas.css?v=1.1" />
    <link rel="stylesheet" href="~/css/Reportes.css?v=4.3" asp-append-version="true" />
}

<partial name="~/Views/Shared/Partials/BotonMenu.cshtml" />

<div class="reportes-page page-99">

    <!-- Header -->
    <div class="cc-header shadow-lg rounded-4 p-4 mb-4">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <span class="cc-badge rpt-badge-main"><i class="fa fa-bar-chart"></i></span>
            <div>
                <h2 class="m-0 fw-800">Reportes</h2>
                <small class="text-muted-cc">Consultas, filtros y exportación AGS MAT</small>
            </div>
            <div class="ms-auto d-flex gap-2 flex-wrap no-print">
                <button type="button" class="btn btn-rpt-ghost btn-sm" id="btnExportarPrint">
                    <i class="fa fa-print me-1"></i> Imprimir
                </button>
                <button type="button" class="btn btn-rpt-accent btn-sm" id="btnExportar">
                    <i class="fa fa-download me-1"></i> Exportar
                </button>
            </div>
        </div>
    </div>

    <!-- Tipo de reporte -->
    <section class="rpt-panel no-print mb-3">
        <div class="rpt-panel__head">
            <i class="fa fa-th-large"></i>
            <span>Tipo de reporte</span>
        </div>
        <div class="rpt-panel__body">
            <nav class="reportes-nav" id="navReportes" aria-label="Tipo de reporte"></nav>
        </div>
    </section>

    <!-- Filtros -->
    <section class="rpt-panel no-print mb-3" id="panelFiltrosReportes">
        <div class="rpt-panel__head">
            <i class="fa fa-filter"></i>
            <span>Filtros</span>
            <span class="rpt-panel__badge" id="reporteActivoLabel">Pedidos por día</span>
        </div>
        <div class="rpt-panel__body">
            <div class="filter-bar rounded-3 p-3">
                <div class="row g-3 align-items-end" id="panelFiltros">
                    <div class="col-lg-2 col-md-4 col-6">
                        <label class="form-label rpt-label" for="filtroDesde">Fecha desde</label>
                        <input type="date" id="filtroDesde" class="form-control rpt-input" />
                    </div>
                    <div class="col-lg-2 col-md-4 col-6">
                        <label class="form-label rpt-label" for="filtroHasta">Fecha hasta</label>
                        <input type="date" id="filtroHasta" class="form-control rpt-input" />
                    </div>
                    <div class="col-lg-3 col-md-6 col-12 filtro-cliente">
                        <label class="form-label rpt-label" for="filtroCliente">Clientes</label>
                        <select id="filtroCliente" class="form-select rpt-select">
                            <option value="-1">— Todos —</option>
                        </select>
                    </div>
                    <div class="col-lg-3 col-md-6 col-12 filtro-proveedor d-none">
                        <label class="form-label rpt-label" for="filtroProveedor">Proveedores</label>
                        <select id="filtroProveedor" class="form-select rpt-select">
                            <option value="-1">— Todos —</option>
                        </select>
                    </div>
                    <div class="col-lg-3 col-md-6 col-12 filtro-producto d-none">
                        <label class="form-label rpt-label" id="lblFiltroProducto">Productos</label>
                        <div class="rpt-prod-check" id="wrapFiltroProductoCheck">
                            <button type="button" class="rpt-prod-check__trigger" id="btnFiltroProductoToggle" aria-expanded="false" aria-haspopup="listbox">
                                <span class="rpt-prod-check__label" id="filtroProductoResumen">Todos los productos</span>
                                <i class="fa fa-chevron-down rpt-prod-check__icon" aria-hidden="true"></i>
                            </button>
                            <div class="rpt-prod-check__drop" id="dropFiltroProducto" hidden>
                                <div class="rpt-prod-check__toolbar">
                                    <input type="search" class="form-control form-control-sm rpt-prod-check__search" id="buscarFiltroProducto" placeholder="Buscar producto…" autocomplete="off" />
                                    <div class="rpt-prod-check__actions">
                                        <button type="button" class="btn btn-link btn-sm p-0" id="btnProdCheckTodos">Marcar todos</button>
                                        <span class="rpt-prod-check__sep">·</span>
                                        <button type="button" class="btn btn-link btn-sm p-0" id="btnProdCheckNinguno">Desmarcar</button>
                                    </div>
                                </div>
                                <div class="rpt-prod-check__list" id="listaFiltroProductoCheck" role="listbox" aria-multiselectable="true"></div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-4 col-6 filtro-tipo d-none">
                        <label class="form-label rpt-label" for="filtroTipo">Tipo</label>
                        <select id="filtroTipo" class="form-select rpt-select">
                            <option value="Cliente">Cliente</option>
                            <option value="Proveedor">Proveedor</option>
                        </select>
                    </div>
                    <div class="col-lg-3 col-md-6 col-12 filtro-entidad d-none">
                        <label class="form-label rpt-label" for="filtroEntidad" id="lblFiltroEntidad">Nombre</label>
                        <select id="filtroEntidad" class="form-select rpt-select">
                            <option value="-1">— Todos —</option>
                        </select>
                    </div>
                    <div class="col-lg-2 col-md-4 col-6 filtro-solo-saldo d-none">
                        <label class="form-label rpt-label d-block">Opciones</label>
                        <div class="form-check rpt-check">
                            <input class="form-check-input" type="checkbox" id="filtroSoloSaldo" />
                            <label class="form-check-label" for="filtroSoloSaldo">Solo con saldo pendiente</label>
                        </div>
                    </div>
                    <div class="col-lg-2 col-md-4 col-12">
                        <label class="form-label rpt-label d-none d-lg-block">&nbsp;</label>
                        <button type="button" class="btn btn-rpt-primary w-100" id="btnGenerar">
                            <i class="fa fa-play me-1"></i> Generar
                        </button>
                    </div>
                </div>
                <p class="rpt-desc mb-0 mt-3" id="reporteDescripcion"></p>
            </div>
        </div>
    </section>

    <!-- Resultados -->
    <section class="rpt-panel">
        <div class="rpt-panel__head">
            <i class="fa fa-table"></i>
            <span>Resultados</span>
            <span class="rpt-panel__meta" id="resultadoMeta"></span>
        </div>
        <div class="rpt-panel__body">
            <div class="reportes-resultado" id="contenedorResultado">
                <div class="rpt-empty">
                    <i class="fa fa-line-chart"></i>
                    <p>Elegí un reporte arriba y presioná <strong>Generar</strong> para ver los datos.</p>
                </div>
            </div>
        </div>
    </section>
</div>

@section Scripts {
    <script src="https://cdnjs.cloudflare.com/ajax/libs/select2/4.0.6-rc.0/js/select2.min.js"></script>
    <script src="~/js/Utils/moment.js"></script>
    <script src="~/js/Reportes.js?v=5.0" asp-append-version="true"></script>
}
