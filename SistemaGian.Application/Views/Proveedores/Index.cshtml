@using Microsoft.Extensions.Configuration
@inject IConfiguration Configuration

@{
    var ambienteTest = Configuration.GetValue<int>("AmbienteTest");
    ViewData["Title"] = "Home Page";
}

@section Estilos {
    <!-- DataTables -->
    <link href="https://cdn.datatables.net/1.11.5/css/jquery.dataTables.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/buttons/2.2.2/css/buttons.dataTables.min.css" rel="stylesheet" />
    <link href="https://cdn.datatables.net/fixedheader/3.2.2/css/fixedHeader.dataTables.min.css" rel="stylesheet" />

    <!-- Icons -->
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/4.7.0/css/font-awesome.min.css">

    <!-- Mismo look & feel que Clientes -->
    <link rel="stylesheet" href="~/css/usuarios.css?v=1.0" />
    <link rel="stylesheet" href="~/css/redisenopantallas.css?v=1.2" />
    <link href="~/css/Proveedores.css?v=1.0" rel="stylesheet" />
    <link href="~/css/RedisenoPantallas.css?v=1.0" rel="stylesheet" />
    <link href="~/css/ClientesMapa.css?v=1.1" rel="stylesheet" />
    <link href="~/css/VisitasAlert.css?v=1.4" rel="stylesheet" />
}

<partial name="~/Views/Shared/Partials/BotonMenu.cshtml" />

<div class="container page-99" style="margin-top:100px">
    <!-- Header “glass” + KPIs (igual a Clientes) -->
    <div class="cc-header shadow-lg rounded-4 p-4 mb-4">
        <div class="d-flex align-items-center gap-3 flex-wrap">
            <div class="d-flex align-items-center gap-3">
                <span class="cc-badge"><i class="fa fa-industry"></i></span>
                <div>
                    <h2 class="m-0 fw-800">Proveedores</h2>
                    <small class="text-muted-cc">Gestión y listado de proveedores</small>
                </div>
            </div>

            <div class="ms-auto d-flex gap-4 flex-wrap align-items-center" id="kpiProveedoresWrap">
                <!-- KPI 1: Cantidad (se actualiza con la grilla filtrada) -->
                <div class="cc-stat">
                    <div class="label">Proveedores</div>
                    <div class="value" id="kpiCantProveedores">0</div>
                </div>

                <!-- Config. Columnas -->
                <div class="dropdown cc-dd">
                    <button id="dropdownColumnas"
                            type="button"
                            class="btn btn-secondary dropdown-toggle d-flex align-items-center"
                            data-bs-toggle="dropdown"
                            data-bs-display="static"
                            data-bs-auto-close="outside"
                            aria-expanded="false">
                        <i class="fa fa-cog me-2"></i>
                        Config. Columnas
                    </button>
                    <ul class="dropdown-menu cc-dropdown-menu" aria-labelledby="dropdownColumnas" id="configColumnasMenu"></ul>
                </div>

                <!-- Nuevo -->
                <a class="btn btn-success d-flex align-items-center px-3 py-2 btnnuevo" onclick="nuevoProveedor()">
                    <i class="fa fa-plus-square me-2"></i> Nuevo
                </a>
            </div>
        </div>
    </div>

    <div class="sv-banner" id="svBanner" hidden>
        <div class="sv-banner-icon"><i class="fa fa-exclamation-triangle"></i></div>
        <div class="sv-banner-text">
            <strong id="svBannerTitle">Tenés proveedores sin visitar</strong>
            <span id="svBannerSub">Sin visita en los últimos 30 días</span>
        </div>
        <button type="button" class="sv-btn" id="svBannerBtn">
            <i class="fa fa-eye me-1"></i> Ver más información
        </button>
    </div>

    <!-- Tarjeta / Tabla -->
    <div class="row g-4">
        <div class="col-12">
            <div class="card-glass p-3">
                <div class="tabla-wrap position-relative">
                    <div class="dt-dark-wrap">
                        <table class="dt-dark display nowrap compact" id="grd_Proveedores" style="width:100%">
                            <thead>
                                <tr>
                                    <th></th>
                                    <th>Nombre</th>
                                    <th>Apodo</th>
                                    <th>Ubicacion</th>
                                    <th>Telefono</th>
                                </tr>
                            </thead>
                            <tbody></tbody>
                        </table>
                    </div>
                </div><!-- /tabla-wrap -->
            </div><!-- /card-glass -->
        </div>
    </div>
</div>

<partial name="~/Views/Shared/Partials/VisitasResumenModal.cshtml" />

<!-- Modal: sin visita reciente -->
<div class="modal fade sv-modal" id="svModal" tabindex="-1" aria-labelledby="svModalTitle" aria-hidden="true">
    <div class="modal-dialog modal-dialog-centered modal-dialog-scrollable">
        <div class="modal-content">
            <div class="modal-header">
                <div>
                    <p class="sv-modal-kicker">Seguimiento</p>
                    <h5 class="modal-title" id="svModalTitle">Proveedores sin visitar</h5>
                    <p class="modal-sub" id="svModalSub">Última visita hace más de 30 días, o nunca visitados.</p>
                </div>
                <button type="button" class="btn-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body">
                <div class="sv-tools">
                    <div class="sv-tools-search">
                        <i class="fa fa-search"></i>
                        <input type="search" id="svFiltro" placeholder="Buscar por nombre, ubicación, teléfono..." />
                    </div>
                    <span class="sv-chip" id="svChipCount">0 proveedores</span>
                    <span class="sv-chip" id="svChipVisible" hidden></span>
                </div>
                <div class="sv-list" id="svModalBody"></div>
            </div>
            <div class="modal-footer">
                <a class="btn btn-outline-primary" href="/Recorridos"><i class="fa fa-map me-1"></i> Ir a Recorridos</a>
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
            </div>
        </div>
    </div>
</div>

<!-- MODAL edición -->
<div class="modal fade" id="modalEdicion" tabindex="-1" role="dialog" aria-labelledby="modalEdicionLabel" aria-hidden="true">
    <div class="modal-dialog modal-xl modal-dialog-centered modal-dialog-scrollable modal-edicion" role="document">
        <div class="modal-content cc-modal cli-map-modal">
            <div class="modal-header colorEncabezado cli-map-header">
                <div class="d-flex align-items-center gap-3">
                    <span class="cli-map-icon"><i class="fa fa-map-marker"></i></span>
                    <div>
                        <h5 class="modal-title fw-bold m-0" id="modalEdicionLabel">Editar proveedor</h5>
                        <small class="cli-map-sub">Datos + ubicación en Google Maps</small>
                    </div>
                </div>
                <button type="button" class="btn-close custom-close" data-bs-dismiss="modal" aria-label="Cerrar"></button>
            </div>
            <div class="modal-body cli-map-body">
                <form id="formEditarProveedor" class="row g-3">
                    <input type="text" id="txtId" hidden readonly>
                    <input type="hidden" id="txtLatitud" />
                    <input type="hidden" id="txtLongitud" />
                    <input type="hidden" id="txtPlaceId" />
                    <input type="hidden" id="txtDireccionMaps" />

                    <div class="col-lg-5">
                        <div class="cli-map-form-panel">
                            <div class="row g-3">
                                <div class="col-md-12">
                                    <label for="txtNombre" class="form-label">Nombre (*)</label>
                                    <input type="text" class="form-control" id="txtNombre" required>
                                </div>
                                <div class="col-md-6">
                                    <label for="txtApodo" class="form-label">Apodo</label>
                                    <input type="text" class="form-control" id="txtApodo">
                                </div>
                                <div class="col-md-6">
                                    <label for="txtTelefono" class="form-label">Teléfono</label>
                                    <input type="text" class="form-control" id="txtTelefono">
                                </div>
                                <div class="col-md-12">
                                    <label for="txtBuscarMaps" class="form-label">Buscar en Maps</label>
                                    <input type="text" class="form-control" id="txtBuscarMaps" placeholder="Calle, número, localidad...">
                                    <small class="text-muted">Elegí sugerencia o mové el pin.</small>
                                </div>
                                <div class="col-md-12">
                                    <label for="txtUbicacion" class="form-label">Ubicación</label>
                                    <input type="text" class="form-control" id="txtUbicacion">
                                </div>
                                <div class="col-12">
                                    <div class="cli-map-coords" id="cliMapCoords">
                                        <span><i class="fa fa-crosshairs"></i> Sin ubicación</span>
                                    </div>
                                    <div class="d-flex flex-wrap gap-2 mt-2">
                                        <button type="button" class="btn btn-outline-primary btn-sm" id="btnMiUbicacionCliente">
                                            <i class="fa fa-location-arrow"></i> Mi ubicación
                                        </button>
                                        <button type="button" class="btn btn-outline-secondary btn-sm" id="btnLimpiarUbicacion">
                                            <i class="fa fa-eraser"></i> Limpiar pin
                                        </button>
                                    </div>
                                </div>
                            </div>
                        </div>
                    </div>
                    <div class="col-lg-7">
                        <div class="cli-map-wrap">
                            <div id="clienteMap" class="cli-map-canvas"></div>
                            <div class="cli-map-hint" id="cliMapHint">Tocá el mapa o buscá una dirección para ubicar al proveedor</div>
                        </div>
                    </div>
                </form>
            </div>
            <div class="modal-footer modal-footer-cc">
                <button type="button" class="btn btn-secondary" data-bs-dismiss="modal">Cerrar</button>
                <button type="button" id="btnGuardar" class="btn btn-primary" onclick="guardarCambios()">Registrar</button>
            </div>
        </div>
    </div>
</div>

<partial name="~/Views/Utils/Modals.cshtml" />

@section Scripts {
    <script src="https://cdn.datatables.net/1.11.5/js/jquery.dataTables.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.2.2/js/dataTables.buttons.min.js"></script>
    <script src="~/js/site.js"></script>
    <script src="https://cdnjs.cloudflare.com/ajax/libs/jszip/3.1.3/jszip.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.2.2/js/buttons.html5.min.js"></script>
    <script src="https://cdn.datatables.net/buttons/2.2.2/js/buttons.print.min.js"></script>
    <script src="https://cdn.datatables.net/fixedheader/3.2.2/js/dataTables.fixedHeader.min.js"></script>

    <script>
        window.__esAdminRecorridos = @(ViewBag.EsAdminRecorridos == true ? "true" : "false");
    </script>
    <script src="~/js/VisitasAlert.js?v=1.2"></script>
    <script src="~/js/Proveedores.js?v=1.9"></script>
    <script src="~/js/ClientesMapa.js?v=1.3"></script>
    <script>
        // Adaptar el helper de mapas de clientes al campo Ubicación de proveedores
        (function () {
            const origSet = window.setClientePos;
            // ClientesMapa escribe en txtDireccion; acá usamos txtUbicacion
            const syncUbicacion = () => {
                const maps = $('#txtDireccionMaps').val();
                if (maps) $('#txtUbicacion').val(maps);
            };
            $('#modalEdicion').on('shown.bs.modal', () => setTimeout(syncUbicacion, 300));
            $('#txtDireccionMaps').on('change input', syncUbicacion);
        })();

        window.__googleMapsApiKey = '@(Configuration["GoogleMaps:ApiKey"] ?? "")';
        (function loadMaps() {
            const key = window.__googleMapsApiKey;
            if (!key || key.indexOf('PEGAR_AQUI') === 0) {
                console.warn('Google Maps API Key no configurada');
                return;
            }
            const s = document.createElement('script');
            s.async = true;
            s.defer = true;
            s.src = 'https://maps.googleapis.com/maps/api/js?key=' + encodeURIComponent(key) + '&libraries=places&callback=initClienteMap';
            document.head.appendChild(s);
        })();
        document.addEventListener('DOMContentLoaded', function () {
            if (window.VisitasAlert) window.VisitasAlert.init({ tipo: 'Proveedor' });
        });
    </script>
}
